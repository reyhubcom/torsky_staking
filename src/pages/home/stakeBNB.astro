---
import Layout from '~/layouts/PageLayout.astro';

import Header from '~/components/widgets/Header.astro';
import Hero from '~/components/widgets/Hero.astro';
import Content from '~/components/widgets/Content.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import Features3 from '~/components/widgets/Features3.astro';
import Testimonials from '~/components/widgets/Testimonials.astro';
import Steps from '~/components/widgets/Steps.astro';
import BlogLatestPosts from '~/components/widgets/BlogLatestPosts.astro';
import { getPermalink } from '~/utils/permalinks';

const metadata = {
  title: 'TORSKY.xyz | Trusted Blockchain Validator',
};
---

<Layout metadata={metadata}>
  <script type='text/javascript' src='https://platform-api.sharethis.com/js/sharethis.js#property=6a50d8c6033ecd05221a3d40&product=sop' async='async'></script>
  <Fragment slot="announcement"></Fragment>
  <Fragment slot="header">
    <Header
      links={[
        { text: 'Home', href: '#' },
        { text: 'Stake', href: '#stake' },
        { text: 'Rewards', href: '#rewards' },
        { text: 'PoS', href: '#pos' },
        
        { text: 'Stake AVAX', href: '/home/stakeAVAX' },
      ]}
      actions={[
        {
          text: 'EXCHANGE',
          href: '#',
        },
      ]}
      isSticky
      showToggleTheme
    />
  </Fragment>

  <!-- Hero2 Widget ******************* -->

  <Hero
    id="hero"
    title="What is Binance Staking?"
    tagline=""
    
    actions={[
      {
        variant: 'primary',
        text: 'Stake NOW',
        href: '#',
        target: '',
        icon: 'tabler:steam',
      },
      {
        text: '',
        text: 'BUY.Wallet',
        href: '#',
        target: '',
        icon: 'tabler:wallet',
      },
    ]}
  >
    <Fragment slot="subtitle">
     Monad staking is the process of locking the native MON tokens on the Monad network to secure the blockchain and earn rewards. By delegating your tokens to a validator, you help the network reach consensus using MonadBFT, yielding a projected 8–12% annual return.
    </Fragment>
  </Hero>

  <!-- Content Widget **************** -->

  <Content
    id="stake"
    columns={3}
    items={[
      {
        icon: 'tabler:steam',
        callToAction: {
          target: '',
          text: 'Stake MON',
          href: '#',
        },
      },
      {
        icon: 'tabler:building-bridge',
        callToAction: {
          target: '',
          text: 'Bridge',
          href: '/home/bridge',
        },
      },
      {
        icon: 'tabler:wallet',
        callToAction: {
          target: '',
          text: 'BUY Wallet',
          href: '#',
        },
      },
    ]}
    image={{
      src: 'https://i.postimg.cc/Dyt8Vqk2/BNB.png',
      alt: 'Colorful Image',
      loading: 'eager',
    }}
  >
    <Fragment slot="content">
      <script defer src="https://www.livecoinwatch.com/static/lcw-widget.js"></script> <div class="livecoinwatch-widget-5" lcw-base="USD" lcw-color-tx="#0693e3" lcw-marquee-1="coins" lcw-marquee-2="movers" lcw-marquee-items="30" ></div>
      <h2 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">What is Staking?</h2>
      <p>
      Proof-of-Stake protocols use staking to create consensus. By locking native tokens into a validator - or indexers on Monad blockchain -, you earn the right to secure a chain and earn rewards on your stake. Due to its environmental efficiency, staking has overtaken mining and is used far more often in newer protocols. 
      </p>
      <br />
      <p>
       How it Works.
      </p>
      <br />
      <p> By locking a protocol’s native tokens to give “validators” the right to secure a chain. Validators propose new blocks or attest other validators’ blocks, gaining rewards for doing so.</p>
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- Steps Widget ****************** -->

  <Steps
    id="rewards"
    title="Staking rewards work "
    items={[
      {
        title:
          ' Lock Tokens:<br /> <span class="font-normal">Select asset: </span> <br /> <span class="text-sm font-normal">Hold duration:  </span>',
        description: `Exchange Staking: One-click staking through platforms like Coinbase or Binance.Staking Pools: Combining funds with others via services like Lido Finance.Solo Staking: Running your own dedicated computer validator node..`,
        icon: 'tabler:wallet',
      },
      {
        title:
          'Secure Network :  <br /> <span class="font-normal">Choose Highly Rated Infrastructure:</span> <br /> <span class="text-sm font-normal">Evaluate Validator Metrics: </span>',
        description: `staking operates in "epochs". Staking actions (like delegating or compounding) usually become active at the start of the next epoch, which occurs approximately every 5.5 hours.`,
        icon: 'tabler:settings-2',
      },
      {
        title:
          'Earn Payouts :  <br /> <span class="font-normal">Select Validator:</span> <br /> <span class="text-sm font-normal">Withdraw Safely:</span>',
        description: `Delegating is generally not instantly withdrawable. To unstake, you must initiate an "undelegate" request and typically wait until the end of an epoch.`,
        icon: 'tabler:clock-dollar',
      },
      {
        title:
          'Compounding :  <br /> <span class="font-normal">Mechanism: </span> <br /> <span class="text-sm font-normal">Liquid staking: </span>',
        description: ` Native staking does not auto-compound; you must manually claim or call a compound function to add rewards back into your staked balance.`,
        icon: 'tabler:new-section',
      },
    ]}
    classes={{ container: 'max-w-3xl' }}
  />

  
 
  <!-- Content Widget **************** -->

  <Content
    id="pos"
    title="The Mechanics of Staking"
    subtitle="Staking is built on a consensus mechanism called Proof-of-Stake (PoS). Instead of using massive computers to solve mathematical puzzles (like Bitcoin's Proof-of-Work), PoS networks rely on users who stake their own crypto as a security deposit."
    isReversed
    items={[
      {
        title: 'Validation: ',
        description:
          ' The network randomly selects validators to propose and confirm new blocks of data (transactions) on the blockchain.',
      },
      {
        title: 'Collateral: ',
        description:
          ' Your locked crypto acts as collateral; if the validator acts dishonestly or goes offline, they risk losing a portion of their staked assets (a process called "slashing").',
      },
      {
        title: 'Rewards:  ',
        description:
          ' If the network confirms the validator performed their duties accurately, they earn a portion of the transaction fees or newly minted tokens.',
      },
    ]}
    image={{
      src: 'https://i.postimg.cc/tgZmhLK7/meca.png',
      alt: 'Tech Design Image',
    }}
    callToAction={{
      target: '_blank',
      text: 'Go to the project',
      icon: 'tabler:chevron-right',
      href: '#',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">
        Proof-of-Stake (PoS): <br /><span class="text-2xl">Choose Your Staking Method</span>
      </h3>
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  
  <!-- Testimonials Widget *********** -->

  <Testimonials
    title="Staking Protocols by Ecosystem "
    subtitle="Crypto staking protocols let you lock up cryptocurrency to secure a Proof-of-Stake (PoS) blockchain network."
    testimonials={[
      {
        testimonial: `Ethereum is an open-source, decentralized blockchain network that acts as a global digital infrastructure. Unlike Bitcoin, which primarily facilitates digital currency payments, Ethereum allows developers to build and deploy automated programs called smart contracts and decentralized applications (dApps).`,
        name: 'Ethereum',
        job: 'ETH',
        image: {
          src: 'https://cryptologos.cc/logos/ethereum-eth-logo.png',
          alt: 'Mark Thompson Image',
        },
      },
      {
        testimonial: `Solana is a high-performance, decentralized blockchain built to host highly scalable, user-friendly applications. It is best known for its lightning-fast transaction speeds (thousands of transactions per second) and ultra-low fees (fractions of a cent). The network's native cryptocurrency is SOL, which is used to pay transaction fees and secure the network through staking.`,
        name: 'Solana',
        job: 'SOL',
        image: {
          src: 'https://cryptologos.cc/logos/solana-sol-logo.png',
          alt: 'Emily Martinez Image',
        },
      },
      {
        testimonial: `Binance is the world's largest cryptocurrency exchange by trading volume. It functions as a digital marketplace where millions of users globally can buy, sell, and trade over 350 different cryptocurrencies, such as Bitcoin (BTC), Ethereum (ETH), and its native token, BNB.`,
        name: 'Binance',
        job: 'BNB',
        image: {
          src: 'https://cryptologos.cc/logos/bnb-bnb-logo.png',
          alt: 'Laura Simmons Image',
        },
      },
      {
        testimonial: `Monad is a high-performance, EVM-compatible Layer-1 blockchain engineered for unprecedented speed and low fees. It processes up to 10,000 transactions per second (TPS) with sub-second finality while allowing developers to seamlessly deploy Ethereum applications without modifying their existing code.`,
        name: 'Monad',
        job: 'MON',
        image: {
          src: 'https://static.chainbroker.io/mediafiles/projects/monad/monad.jpeg',
          alt: 'Alex Foster Image',
        },
      },
      {
        testimonial: `Avalanche (AVAX) is a decentralized layer-1 blockchain designed for speed, customizability, and decentralized finance (DeFi). It features near-instant transaction finality (under one second) and supports the creation of custom, interoperable blockchains, making it a popular platform for large-scale applications and tokenized real-world assets.`,
        name: 'Avalanche',
        job: 'AVAX',
        image: {
          src: 'https://cryptologos.cc/logos/avalanche-avax-logo.png',
          alt: 'Jessica Collins Image',
        },
      },
      {
        testimonial: `Gram (GRAM) is the native cryptocurrency of The Open Network (TON). Heavily integrated with the Telegram messaging app, it is used to pay transaction fees, participate in network governance via validator staking, and fuel decentralized applications (dApps) within the ecosystem.`,
        name: 'GRAM',
        job: 'GRAM',
        image: {
          src: 'https://upload.wikimedia.org/wikipedia/commons/thumb/0/0b/Gram_cryptocurrency_logo.svg/960px-Gram_cryptocurrency_logo.svg.png?_=20191101175514',
          alt: 'Michael Carter Image',
        },
      },
    ]}
  />

   <script>
  (function(){var w=window;if(w.ChannelIO){return w.console.error("ChannelIO script included twice.");}var ch=function(){ch.c(arguments);};ch.q=[];ch.c=function(args){ch.q.push(args);};w.ChannelIO=ch;function l(){if(w.ChannelIOInitialized){return;}w.ChannelIOInitialized=true;var s=document.createElement("script");s.type="text/javascript";s.async=true;s.src="https://cdn.channel.io/plugin/ch-plugin-web.js";var x=document.getElementsByTagName("script")[0];if(x.parentNode){x.parentNode.insertBefore(s,x);}}if(document.readyState==="complete"){l();}else{w.addEventListener("DOMContentLoaded",l);w.addEventListener("load",l);}})();

  ChannelIO('boot', {
    "pluginKey": "aaf5fdca-a626-4b78-b14f-b26abc0da15b"
  });
</script>
</Layout>
